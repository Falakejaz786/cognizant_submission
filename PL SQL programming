-- Exercise 3: Stored Procedure

CREATE OR REPLACE PROCEDURE ProcessMonthlyInterest AS
BEGIN
    UPDATE Accounts
    SET Balance = Balance + (Balance * 0.01)
    WHERE AccountType = 'Savings';
END;
/

CREATE OR REPLACE PROCEDURE TransferFunds(
    p_from NUMBER,
    p_to NUMBER,
    p_amount NUMBER
) AS
    v_balance NUMBER;
BEGIN
    SELECT Balance INTO v_balance
    FROM Accounts
    WHERE AccountID = p_from;

    IF v_balance >= p_amount THEN
        UPDATE Accounts
        SET Balance = Balance - p_amount
        WHERE AccountID = p_from;

        UPDATE Accounts
        SET Balance = Balance + p_amount
        WHERE AccountID = p_to;
    END IF;
END;
/

-- Exercise 4: Functions

CREATE OR REPLACE FUNCTION CalculateAge(
    p_dob DATE
) RETURN NUMBER
AS
BEGIN
    RETURN FLOOR(MONTHS_BETWEEN(SYSDATE, p_dob)/12);
END;
/

CREATE OR REPLACE FUNCTION HasSufficientBalance(
    p_account NUMBER,
    p_amount NUMBER
) RETURN NUMBER
AS
    v_balance NUMBER;
BEGIN
    SELECT Balance INTO v_balance
    FROM Accounts
    WHERE AccountID = p_account;

    IF v_balance >= p_amount THEN
        RETURN 1;
    ELSE
        RETURN 0;
    END IF;
END;
/

-- Exercise 5: Trigger

CREATE OR REPLACE TRIGGER UpdateCustomerLastModified
BEFORE UPDATE ON Customers
FOR EACH ROW
BEGIN
    :NEW.LastModified := SYSDATE;
END;
/

-- Exercise 2: Error Handling

CREATE OR REPLACE PROCEDURE SafeTransferFunds(
    p_from NUMBER,
    p_to NUMBER,
    p_amount NUMBER
) AS
BEGIN
    TransferFunds(p_from, p_to, p_amount);
    COMMIT;
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Transfer Failed');
END;
/

-- Exercise 7: Package

CREATE OR REPLACE PACKAGE CustomerManagement AS
    PROCEDURE AddCustomer(
        p_id NUMBER,
        p_name VARCHAR2,
        p_dob DATE,
        p_balance NUMBER
    );

    FUNCTION GetBalance(
        p_id NUMBER
    ) RETURN NUMBER;
END;
/

CREATE OR REPLACE PACKAGE BODY CustomerManagement AS

    PROCEDURE AddCustomer(
        p_id NUMBER,
        p_name VARCHAR2,
        p_dob DATE,
        p_balance NUMBER
    ) AS
    BEGIN
        INSERT INTO Customers
        VALUES (p_id, p_name, p_dob, p_balance, SYSDATE);
    END;

    FUNCTION GetBalance(
        p_id NUMBER
    ) RETURN NUMBER
    AS
        v_balance NUMBER;
    BEGIN
        SELECT Balance INTO v_balance
        FROM Customers
        WHERE CustomerID = p_id;

        RETURN v_balance;
    END;

END;
/
