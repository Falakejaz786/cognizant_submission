public class ApiGatewayDemo {

    public static void main(String[] args) {

        // Exercise 1 - Routing & Filtering
        System.out.println("Request received: /example/test");
        System.out.println("Routing to example service");

        // Exercise 2 - Load Balancing
        String[] servers = {"Service-1", "Service-2"};
        for (int i = 0; i < 4; i++) {
            System.out.println("Request routed to "
                    + servers[i % servers.length]);
        }

        // Exercise 3 - Resilience Pattern
        try {
            throw new RuntimeException("Service Down");
        } catch (Exception e) {
            System.out.println("Fallback executed: " + e.getMessage());
        }
    }
}
