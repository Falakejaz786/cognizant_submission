            throws Exception {

        ExecutorService service =
                Executors.newFixedThreadPool(3);

        Callable<Integer> task1 =
                () -> 10 + 20;

        Callable<Integer> task2 =
                () -> 50 + 50;

        Future<Integer> result1 =
                service.submit(task1);

        Future<Integer> result2 =
                service.submit(task2);

        System.out.println(
                result1.get()
        );

        System.out.println(
                result2.get()
        );

        service.shutdown();
    }
}
